<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>org.plovdev</groupId>
  <artifactId>PornViewer</artifactId>
  <version>1.0-SNAPSHOT</version>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <transformers>
                <transformer>
                  <mainClass>com.plovdev.pornviewer.Launcher</mainClass>
                </transformer>
                <transformer />
              </transformers>
              <artifactSet>
                <excludes>
                  <exclude>com.google.errorprone:error_prone_annotations</exclude>
                  <exclude>org.checkerframework:checker-qual</exclude>
                  <exclude>com.google.code.findbugs:jsr305</exclude>
                  <exclude>org.jetbrains.kotlin:kotlin-stdlib-common</exclude>
                  <exclude>org.intellij.lang.annotations:annotations</exclude>
                </excludes>
              </artifactSet>
              <filters>
                <filter>
                  <artifact>*:*</artifact>
                  <excludes>
                    <exclude>META-INF/versions/9/module-info.class</exclude>
                    <exclude>module-info.class</exclude>
                    <exclude>META-INF/MANIFEST.MF</exclude>
                    <exclude>META-INF/native-image/**</exclude>
                    <exclude>META-INF/substrate/**</exclude>
                  </excludes>
                </filter>
                <filter>
                  <artifact>io.github.willena:sqlite-jdbc</artifact>
                  <excludes>
                    <exclude>org/sqlite/native/Windows/**</exclude>
                    <exclude>org/sqlite/native/Linux/**</exclude>
                    <exclude>org/sqlite/native/linux/**</exclude>
                    <exclude>org/sqlite/native/FreeBSD/**</exclude>
                    <exclude>org/sqlite/native/Android/**</exclude>
                    <exclude>org/sqlite/native/Linux-Android/**</exclude>
                    <exclude>org/sqlite/native/Linux-Musl/**</exclude>
                    <exclude>org/sqlite/native/readme.txt</exclude>
                    <exclude>META-INF/native-image/**</exclude>
                    <exclude>META-INF/substrate/**</exclude>
                  </excludes>
                </filter>
                <filter>
                  <artifact>org.openjfx:javafx-base</artifact>
                  <excludes>
                    <exclude>META-INF/substrate/**</exclude>
                  </excludes>
                </filter>
                <filter>
                  <artifact>org.openjfx:javafx-controls</artifact>
                  <excludes>
                    <exclude>META-INF/substrate/**</exclude>
                  </excludes>
                </filter>
                <filter>
                  <artifact>org.openjfx:javafx-graphics</artifact>
                  <excludes>
                    <exclude>META-INF/substrate/**</exclude>
                  </excludes>
                </filter>
                <filter>
                  <artifact>org.openjfx:javafx-media</artifact>
                  <excludes>
                    <exclude>META-INF/substrate/**</exclude>
                  </excludes>
                </filter>
              </filters>
              <createSourcesJar>false</createSourcesJar>
              <shadedArtifactAttached>false</shadedArtifactAttached>
              <minimizeJar>false</minimizeJar>
              <outputDirectory>./input-pv</outputDirectory>
              <finalName>PornViewer</finalName>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <properties>
    <maven.compiler.target>21</maven.compiler.target>
    <maven.compiler.source>21</maven.compiler.source>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <javafx.version>20.0.2</javafx.version>
  </properties>
</project>
